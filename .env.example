# DevIntel Environment Variables
# Copy this file to .env and fill in your values (never commit .env)

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- CORS ----
# URL of the frontend when running it separately from the Express server.
# In production the server serves the client itself, so this is not needed.
# CLIENT_ORIGIN=http://localhost:8080

# ---- GitHub API (HIGHLY RECOMMENDED) ----
# Without a token: 60 requests/hr (shared across all users hitting your server)
# With a token:  5000 requests/hr
# Create at: https://github.com/settings/tokens/new (no scopes needed for public repos)
# GITHUB_TOKEN=ghp_your_token_here

# ---- Server-side cache TTLs (milliseconds, optional overrides) ----
# CACHE_TTL_NEWS=600000      # Dev.to articles: 10 minutes (default)
# CACHE_TTL_GITHUB=900000    # GitHub search:   15 minutes (default)
# CACHE_TTL_HN_TOP=300000    # HN top IDs:       5 minutes (default)
# CACHE_TTL_HN_ITEM=1800000  # HN story items:  30 minutes (default)
