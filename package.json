{
  "name": "devintel",
  "version": "2.0.0",
  "description": "Developer news aggregator PWA — full-stack with Express backend",
  "main": "server/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:css": "tailwindcss --config ./config/tailwind.config.js -i ./client/css/input.css -o ./client/css/styles.css --minify",
    "watch:css": "tailwindcss --config ./config/tailwind.config.js -i ./client/css/input.css -o ./client/css/styles.css --watch",
    "build:icons": "node scripts/generate-icons.js",
    "build": "npm run build:icons && npm run build:css",
    "start": "node server/index.js",
    "dev": "concurrently \"nodemon server/index.js --ignore client/\" \"npm run watch:css\"",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:cov": "jest --coverage",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.js",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.js --ui",
    "lint:css": "stylelint client/css/input.css",
    "ci": "npm run build && npm run test:unit:cov"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": ["**/tests/unit/**/*.test.js"],
    "collectCoverageFrom": [
      "client/js/ui.js",
      "client/js/api.js",
      "server/routes/**/*.js",
      "server/middleware/**/*.js",
      "!server/middleware/rateLimit.js"
    ],
    "coverageReporters": ["text", "lcov"]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mzayaan/DevIntel.git"
  },
  "keywords": ["pwa", "developer", "news", "aggregator"],
  "author": "Mohammad Zayaan Husain Dulmeer",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mzayaan/DevIntel/issues"
  },
  "homepage": "https://github.com/mzayaan/DevIntel#readme",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nock": "^13.5.4",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.31",
    "sharp": "^0.33.3",
    "stylelint": "^16.5.0",
    "stylelint-config-standard": "^36.0.0",
    "supertest": "^6.3.4",
    "tailwindcss": "^3.3.0"
  }
}
