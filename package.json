  "description": "Developer news aggregator with trending repos, articles, and bookmarks",
  "main": "src/index.html",
  "scripts": {
    "build:css": "tailwindcss --config ./config/tailwind.config.js -i ./src/css/input.css -o ./src/css/styles.css",
